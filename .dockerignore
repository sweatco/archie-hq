# Dependencies
node_modules/

# Build output (will be rebuilt in container)
dist/

# Sessions (mounted as volume)
sessions/

# Repos (mounted as volume)
repos/

# Secrets (mounted as volume)
secrets/
*.pem

# Environment files (passed via env_file or environment)
.env
.env.local
.env.*.local

# Development files
.git/
.gitignore
*.md
docs/
plans/

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Testing
coverage/
.nyc_output/

# Opt-in extra CA for TLS-intercepting proxies (build needs it for npm; not a secret)
!secrets/extra-ca.crt
