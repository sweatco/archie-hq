{
  "name": "archie-hq",
  "version": "0.1.0",
  "description": "Archie - Autonomous Responsive and Collaborative Hyper Intelligent Employee",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli/index.tsx",
    "docker:dev": "docker compose up --build",
    "docker:stop": "docker compose down",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.96",
    "@aws-sdk/client-bedrock-runtime": "^3.1020.0",
    "@octokit/app": "^16.1.2",
    "@octokit/webhooks": "^14.2.0",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.0.0",
    "dotenv": "^16.3.0",
    "gray-matter": "^4.0.3",
    "ink": "^5.2.1",
    "ink-scroll-view": "^0.3.6",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "picocolors": "^1.1.1",
    "react": "^18.3.1",
    "slackify-markdown": "^4.5.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.28",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
