{
  "name": "archie-hq",
  "version": "0.1.0",
  "description": "Archie - Autonomous Responsive and Collaborative Hyper Intelligent Employee",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "dist/index.js",
  "packageManager": "npm@11.16.0",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli/index.tsx",
    "example:setup": "mkdir -p workdir && ln -sfn ../examples/plugins workdir/plugins && echo 'Linked examples/plugins -> workdir/plugins (leave ARCHIE_PLUGINS unset to use it).'",
    "oauth": "tsx src/cli/oauth.ts",
    "oauth:connect": "tsx src/cli/oauth.ts connect",
    "oauth:list": "tsx src/cli/oauth.ts list",
    "oauth:revoke": "tsx src/cli/oauth.ts revoke",
    "oauth:refresh": "tsx src/cli/oauth.ts refresh",
    "memory:housekeeping": "tsx scripts/memory-housekeeping.ts",
    "docker:dev": "docker compose up --build",
    "docker:stop": "docker compose down",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.187",
    "@anthropic-ai/sdk": "^0.105.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1075.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/app": "^16.1.2",
    "@octokit/webhooks": "^14.2.0",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.17.0",
    "chrono-node": "^2.9.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "ink": "^7.1.0",
    "ink-scroll-view": "^0.3.6",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "oauth4webapi": "^3.8.6",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
