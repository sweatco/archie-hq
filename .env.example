# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Claude Code CLI path - point directly to cli.js
CLAUDE_PATH=/path/to/claude

# Model versions
SONNET_MODEL=claude-sonnet-4-5-20250929
HAIKU_MODEL=claude-haiku-4-5-20251001

# Slack Configuration (HTTP webhooks)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Working directory (all state lives here: plugins, repos, sessions)
# Default: ./workdir
# ARCHIE_WORKDIR=./workdir

# Plugins repo (git URL — cloned into $ARCHIE_WORKDIR/plugins on startup)
# If unset, $ARCHIE_WORKDIR/plugins must already exist
ARCHIE_PLUGINS=https://github.com/your-org/your-plugins-repo.git

# GitHub App (for PR management)
GITHUB_APP_ID=123456
GITHUB_APP_SLUG=archie-hq
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-private-key.pem
GITHUB_INSTALLATION_ID=12345678
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# MCP Plugin Servers (substituted into plugins/.mcp.json)
MCP_ATLASSIAN_TOKEN=base64(user@example.com:your-api-token)

# Server Configuration
PORT=3000