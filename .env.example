# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Claude Code CLI path - point directly to cli.js
CLAUDE_PATH=/path/to/claude

# Slack Configuration (optional — omit for CLI-only mode)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# Set SLACK_APP_TOKEN (xapp-...) to use Socket Mode instead of HTTP webhooks.
# Requires `connections:write` scope on an app-level token. When set, no public
# webhook URL is needed — events flow over an outbound WebSocket.
# SLACK_APP_TOKEN=xapp-...

# Live "Archie is …" status indicator while a task is working. Surface-agnostic:
# the same line is rendered to the CLI and (best-effort) the Slack assistant-
# thread loading state. DEFAULTS ON; set to 'false' to disable on all surfaces.
# Slack rendering additionally needs assistant:write or chat:write (both in the
# manifest) and the Agents & AI Apps toggle on the bot.
ARCHIE_LIVE_STATUS=true

# Working directory (all state lives here: plugins, repos, sessions)
# Default: ./workdir
# ARCHIE_WORKDIR=./workdir

# Plugins repo (git URL — cloned into $ARCHIE_WORKDIR/plugins on startup).
# If unset, $ARCHIE_WORKDIR/plugins must already exist (e.g. a local checkout or
# symlink). To try the bundled example plugins, leave this UNSET and run
# `npm run example:setup` (symlinks examples/plugins -> workdir/plugins).
# To use your own plugins, set this to their git URL:
# ARCHIE_PLUGINS=https://github.com/your-org/your-plugins-repo.git

# Memory layer (auto-learns from completed tasks). Injection into prompts is a
# separate, default-off gate — see ARCHIE_MEMORY_INJECT below.
# Set to 'false' to disable the whole layer (both extraction and injection).
ARCHIE_MEMORY=true

# Memory injection (read path): inject stored facts into agent prompts.
# Independent of extraction and DEFAULTS OFF (opposite of the other flags here).
# Leave unset/false to collect & evaluate facts without changing agent behavior;
# set to 'true' to actually inject memory. ARCHIE_MEMORY=false overrides this.
ARCHIE_MEMORY_INJECT=false

# Memory housekeeping (periodic Sonnet pass merges duplicates, drops stale entries)
# Set to 'false' to disable both automatic and manual housekeeping
ARCHIE_MEMORY_HOUSEKEEPING=true
# Per-user total-bullet soft cap; consolidation auto-triggers when exceeded
ARCHIE_MEMORY_USER_CAP=100
# Per-section soft cap
ARCHIE_MEMORY_SECTION_CAP=30
# Days after which an unrefreshed bullet becomes eligible for removal
ARCHIE_MEMORY_STALENESS_DAYS=180
# Entity layer: soft cap on total entity pages; entity housekeeping (merge/archive) auto-triggers when exceeded
ARCHIE_MEMORY_ENTITY_CAP=300
# Max full entity pages pushed into a single agent prompt (the thin index is always injected in full)
ARCHIE_MEMORY_ENTITY_INJECT_MAX=8

# GitHub App (for PR management)
GITHUB_APP_ID=123456
GITHUB_APP_SLUG=archie-hq
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-private-key.pem
GITHUB_INSTALLATION_ID=12345678
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# MCP Plugin Servers (substituted into plugins/.mcp.json)
MCP_ATLASSIAN_TOKEN=base64(user@example.com:your-api-token)
MCP_BUGSNAG_AUTH_TOKEN=your-bugsnag-personal-auth-token
MCP_BUGSNAG_PROJECT_API_KEY=your-bugsnag-project-api-key
MCP_TEAMCITY_URL=https://your-teamcity-instance.com
MCP_TEAMCITY_TOKEN=tc_your-api-token
MCP_FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account-key.json
MCP_ROLLBAR_ACCESS_TOKEN=your-rollbar-post-server-item-access-token

# OAuth-based MCP servers
# Generate the key once and append it directly to .env so the value
# never hits stdout or shell history (prefix with a space when
# HIST_IGNORE_SPACE is on):
#   echo "ARCHIE_SECRETS_KEY=$(openssl rand -base64 32 | tr -d '\n')" >> .env
# Required when any OAuth records exist; the CLI also requires it.
ARCHIE_SECRETS_KEY=
# Public HTTPS URL where the daemon is reachable. The OAuth provider
# redirects browsers to ${ARCHIE_PUBLIC_URL}/oauth/callback after
# the operator authorizes. Required to run `oauth:connect`.
ARCHIE_PUBLIC_URL=
# Override for the secrets directory. Default: /app/secrets in container,
# <repo>/secrets locally.
# ARCHIE_SECRETS_DIR=

# Server Configuration
PORT=3000